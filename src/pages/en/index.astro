---
import Layout from '../../components/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Card from '../../components/Card.astro';
import Button from '../../components/Button.astro';
import HeroVanta from '../../components/HeroVanta.astro';
import { projects } from '../../data/projects.en';

const featuredProjects = projects.filter(p => p.featured);
const focusItems = [
  'Web development and modern application architecture',
  'Building useful, real-world software projects',
  'Automation and improving workflows',
  'Continuous growth while completing my IT education',
  'Professional development through hands-on industry experience',
];
const exploreItems = [
  {
    title: 'Notes',
    description: 'Ideas, observations, and technical notes.',
    href: 'https://notes.fastory.me',
    icon: 'notes',
  },
  {
    title: 'Learning Journal',
    description: 'School work, practice logs, and progress over time.',
    href: 'https://portfolio.fastory.me',
    icon: 'journal',
  },
  {
    title: 'Links',
    description: 'A curated place for my public links and profiles.',
    href: 'https://links.fastory.me',
    icon: 'links',
  },
];
---

<Layout
  title="Home"
  description="Arseniy Domanov - IT student in Norway focused on engineering, systems, and security"
  locale="en"
>
  <Navbar locale="en" currentPath="" />

  <main class="min-h-screen flex flex-col">
    <HeroVanta locale="en" />

    <section class="section-container pt-12 pb-10 md:pt-14 md:pb-12">
      <div class="section-heading">
        <h2>Featured Projects</h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {featuredProjects.map(project => (
          <Card>
            <h3 class="mb-2 text-lg font-bold text-white">{project.title}</h3>
            <p class="mb-4 text-sm leading-6 text-dark-muted">{project.description}</p>
            <div class="mb-4 flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="pill">{tag}</span>
              ))}
            </div>
            <div class="flex items-center justify-between">
              <span class={`rounded-full px-3 py-1 text-xs ${
                project.status === 'Active' ? 'bg-green-500/10 text-green-400' :
                project.status === 'In Progress' ? 'bg-blue-500/10 text-blue-400' :
                project.status === 'Completed' ? 'bg-purple-500/10 text-purple-400' :
                'bg-gray-500/10 text-gray-400'
              }`}>
                {project.status}
              </span>
              {project.link && (
                <a href={project.link} class="text-sm text-accent hover:text-accent-light">
                  View ->
                </a>
              )}
            </div>
          </Card>
        ))}
      </div>

      <div class="mt-8 text-center">
        <Button href="/en/projects" variant="secondary">
          View all projects
        </Button>
      </div>
    </section>

    <section class="section-container py-10 md:py-12">
      <div class="section-heading">
        <h2>Explore</h2>
        <p>Other parts of the site worth checking out.</p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {exploreItems.map(item => (
          <Card href={item.href}>
            <div class="mb-4 flex items-start justify-between">
              <div class="icon-box">
                {item.icon === 'notes' && (
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                  </svg>
                )}
                {item.icon === 'journal' && (
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                  </svg>
                )}
                {item.icon === 'links' && (
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                  </svg>
                )}
              </div>
              <span class="text-sm text-dark-muted">-></span>
            </div>
            <h3 class="mb-2 text-xl font-bold text-white">{item.title}</h3>
            <p class="text-sm leading-6 text-dark-muted">{item.description}</p>
          </Card>
        ))}
      </div>
    </section>

    <section class="section-container py-10 md:py-12">
      <div class="section-heading">
        <h2>Areas of Focus</h2>
        <p>What I'm Interested In</p>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {focusItems.map(item => (
          <div class="surface-card flex items-center gap-3 p-5">
            <span class="flex h-5 w-5 shrink-0 items-center justify-center leading-none text-accent">▸</span>
            <p class="leading-6 text-dark-text">{item}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section-container py-10 md:py-12">
      <div class="surface-card p-6 md:p-8">
        <div class="max-w-3xl">
          <h2 class="mb-4 text-3xl font-extrabold text-white md:text-4xl">About</h2>
          <p class="mb-6 text-lg leading-8 text-dark-muted">
            I'm an IT student and developer based in Norway, focused on web development, practical software projects, and learning through real work.
          </p>
          <Button href="/en/about" variant="secondary">
            Read more
          </Button>
        </div>
      </div>
    </section>
  </main>

  <Footer locale="en" />
</Layout>
