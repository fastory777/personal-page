---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = '' } = Astro.props;
const isLink = !!href;

const baseClasses = 'surface-card p-6';
---

{
  isLink ? (
    <a href={href} class={`block ${baseClasses} surface-card-hover ${className}`}>
      <slot />
    </a>
  ) : (
    <div class={`${baseClasses} ${className}`}>
      <slot />
    </div>
  )
}
