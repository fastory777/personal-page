---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const variantClasses = {
  primary: 'bg-accent text-white hover:bg-accent-light',
  secondary: 'bg-dark-surface text-dark-text border border-dark-border hover:border-accent hover:text-accent',
  ghost: 'text-dark-text hover:text-accent',
};

const baseClasses = 'inline-flex items-center justify-center rounded-lg px-6 py-3 text-sm font-semibold transition-all duration-200';
const classes = `${baseClasses} ${variantClasses[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button class={classes}>
      <slot />
    </button>
  )
}
